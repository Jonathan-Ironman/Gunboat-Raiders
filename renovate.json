{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":semanticCommitTypeAll(chore)"],
  "timezone": "Europe/Amsterdam",
  "schedule": ["before 6am on monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "dependencyDashboard": true,
  "rangeStrategy": "bump",
  "labels": ["dependencies", "renovate"],
  "minimumReleaseAge": "14 days",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Never automerge pre-1.0.0 packages (unstable semver)",
      "matchCurrentVersion": "\u003c1.0.0",
      "automerge": false
    },
    {
      "description": "Automerge patch+minor for all stable deps",
      "matchUpdateTypes": ["patch", "minor"],
      "matchCurrentVersion": "\u003e=1.0.0",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Automerge pin and digest updates (safe, no version change)",
      "matchUpdateTypes": ["pin", "digest"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Next.js major updates - PR only, no automerge",
      "matchPackageNames": ["next", "/^@next/"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["nextjs-major", "manual-migration"]
    },
    {
      "description": "All major updates require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update"]
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 6am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 6am on monday"],
    "addLabels": ["security"]
  },
  "osvVulnerabilityAlerts": true,
  "updateNotScheduled": false
}
